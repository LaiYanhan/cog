            {%- else %} contracts
            {%- endif %} by directly editing the relevant code files.
        </step>
    </workflow>

    <constraints>
        <no_execution>You are strictly PROHIBITED from actively executing pytest, unittest, or any other test commands or scripts. Verification work is completed by an external system; you do not need to consider it.</no_execution>
        <operation>You are only allowed to modify or add content within the /app/code/ folder
            {%- if mode | default('tdd') != 'rdd' %}, excluding the tests subfolder
            {%- endif %}. It is strictly PROHIBITED to make any changes to the /app/requirement.xml file
            {%- if mode | default('tdd') != 'rdd' %} or the /app/code/tests/ folder
